---
import type { CollectionEntry } from "astro:content";
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import TagPill from "@/components/blog/TagPill.astro";
import { getAllPosts, getUniqueTagsWithCount, groupPostsByYear } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";
import { translations } from "@/i18n/translations";

const t = translations.pl.pages.posts;
const pagination = translations.pl.pagination;

export const getStaticPaths = (async ({ paginate }) => {
  const MAX_POSTS_PER_PAGE = 10;
  const MAX_TAGS = 7;
  const MAX_PINNED_POSTS = 3;
  const allPosts = await getAllPosts();
  const allPostsByDate = allPosts.sort(collectionDateSort);
  const uniqueTags = getUniqueTagsWithCount(allPosts).slice(0, MAX_TAGS);
  const pinnedPosts = allPostsByDate
    .filter((p) => p.data.pinned)
    .slice(0, MAX_PINNED_POSTS);
  return paginate(allPostsByDate, {
    pageSize: MAX_POSTS_PER_PAGE,
    props: { uniqueTags, pinnedPosts },
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"artykul">>;
  uniqueTags: [string, number][];
  pinnedPosts: CollectionEntry<"artykul">[];
}

const { page, uniqueTags, pinnedPosts } = Astro.props;

const meta = {
  description: t.meta.description,
  title: t.meta.title,
};

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: pagination.previousPage,
      url: page.url.prev,
    },
  }),
  ...(page.url.next && {
    nextUrl: {
      text: pagination.nextPage,
      url: page.url.next,
    },
  }),
};

const groupedByYear = groupPostsByYear(page.data);
const descYearKeys = Object.keys(groupedByYear).sort((a, b) => +b - +a);
---

<PageLayout meta={meta} breadcrumbs={[{ label: "artykuły" }]}>
  <div class="header">
    <h1 class="section-title section-title--large">{t.title}</h1>
    <a class="rss" href="/rss.xml" target="_blank">
      <span class="sr-only">{t.rssFeed}</span>
      <Icon
        aria-hidden="true"
        class="rss-icon"
        focusable="false"
        name="mdi:rss"
      />
    </a>
  </div>
  {
    pinnedPosts.length > 0 && (
      <section class="index-section" aria-labelledby="pinned-posts">
        <h2 id="pinned-posts" class="index-section-title">
          {t.pinnedPosts}
        </h2>
        <ol class="post-list">
          {pinnedPosts.map((p) => (
            <li>
              <PostPreview as="h3" post={p} />
            </li>
          ))}
        </ol>
      </section>
    )
  }
  {
    descYearKeys.map((yearKey) => (
      <section class="index-section" aria-labelledby={`year-${yearKey}`}>
        <h2 id={`year-${yearKey}`} class="index-section-title">
          <span class="sr-only">{t.postsIn}</span>
          {yearKey}
        </h2>
        <ol class="post-list">
          {groupedByYear[yearKey]?.map((p) => (
            <li>
              <PostPreview as="h3" post={p} />
            </li>
          ))}
        </ol>
      </section>
    ))
  }
  <Pagination {...paginationProps} />
  {
    !!uniqueTags.length && (
      <aside class="tags">
        <h2 class="tags-title">
          {t.tags}
          <svg
            aria-hidden="true"
            class="tags-icon"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M0 0h24v24H0z" fill="none" stroke="none" />
            <path d="M7.859 6h-2.834a2.025 2.025 0 0 0 -2.025 2.025v2.834c0 .537 .213 1.052 .593 1.432l6.116 6.116a2.025 2.025 0 0 0 2.864 0l2.834 -2.834a2.025 2.025 0 0 0 0 -2.864l-6.117 -6.116a2.025 2.025 0 0 0 -1.431 -.593z" />
            <path d="M17.573 18.407l2.834 -2.834a2.025 2.025 0 0 0 0 -2.864l-7.117 -7.116" />
            <path d="M6 9h-.01" />
          </svg>
        </h2>
        <ul class="tags-list">
          {uniqueTags.map(([tag, count]) => (
            <li>
              <TagPill
                tag={tag}
                href={`/tagi/${tag}/`}
                count={count}
                title={`${t.viewAllPostsWithTag}: ${tag}`}
              />
            </li>
          ))}
        </ul>
        <a class="view-all" href="/tagi/">
          {t.viewAllTags} <span aria-hidden="true">→</span>
          <span class="sr-only">{t.viewAllTagsSr}</span>
        </a>
      </aside>
    )
  }
</PageLayout>

<style>
  .header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-block-end: var(--space-lg);
  }

  .rss {
    color: var(--color-accent);
    text-decoration: none;
  }

  .rss-icon {
    inline-size: 1.5rem;
    block-size: 1.5rem;
  }

  .tags {
    margin-block-start: var(--space-md);
  }

  .tags-title {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-block-end: var(--space-sm);
    color: var(--color-accent-2);
    font-size: var(--text-h4);
    font-weight: var(--font-medium);
    line-height: var(--leading-h4);
  }

  .tags-icon {
    inline-size: 1.5rem;
    block-size: 1.5rem;
  }

  .tags-list {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 12rem), 1fr));
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .view-all {
    display: block;
    margin-block-start: var(--space-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;

    &:hover {
      color: var(--color-link);
    }

    @media (min-width: 40rem) {
      text-align: end;
    }
  }
</style>
