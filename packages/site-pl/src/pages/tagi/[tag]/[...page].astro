---
import { render } from "astro:content";
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts, getTagMeta, getUniqueTags } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { translations } from "@/i18n/translations";

const t = translations.pl.pages.tags;
const pagination = translations.pl.pagination;

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getAllPosts();
  const sortedPosts = allPosts.sort(collectionDateSort);
  const uniqueTags = getUniqueTags(sortedPosts);

  return uniqueTags.flatMap((tag) => {
    const postsWithTag = sortedPosts.filter((post) =>
      post.data.tags.includes(tag),
    );
    return paginate(postsWithTag, {
      pageSize: 10,
      params: { tag },
    });
  });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const { tag } = Astro.params;
const tagMeta = await getTagMeta(tag);

const TagContent = tagMeta ? (await render(tagMeta)).Content : null;

const meta = {
  description: tagMeta?.data.description ?? `${t.viewAllPostsWithTag} - ${tag}`,
  title: tagMeta?.data.title ?? `${t.postsAbout} ${tag}`,
};

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: pagination.previousTags,
      url: page.url.prev,
    },
  }),
  ...(page.url.next && {
    nextUrl: {
      text: pagination.nextTags,
      url: page.url.next,
    },
  }),
};
---

<PageLayout
  meta={meta}
  breadcrumbs={[
    { label: "tagi", href: "/tagi/" },
    { label: `#${tag}` },
  ]}
>
  <header class="tag-hero">
    <span class="tag-hero__kicker">#{tag}</span>
    <h1>{tagMeta?.data.title ?? `${t.postsAbout} ${tag}`}</h1>
    {
      (tagMeta?.data.description || TagContent) && (
        <div class="tag-hero__body prose">
          {tagMeta?.data.description && <p>{tagMeta.data.description}</p>}
          {TagContent && <TagContent />}
        </div>
      )
    }
  </header>

  <ol class="post-list">
    {
      page.data.map((p) => (
        <li>
          <PostPreview as="h2" post={p} />
        </li>
      ))
    }
  </ol>
  <Pagination {...paginationProps} />
</PageLayout>

<style>
  .tag-hero {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-block-end: 2.5rem;
    padding-block-end: 1.5rem;
    border-block-end: 1px solid var(--color-hairline);
  }

  .tag-hero__kicker {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-ultra);
    text-transform: uppercase;
  }

  .tag-hero h1 {
    margin: 0;
    text-transform: capitalize;
  }

  .tag-hero__body {
    max-inline-size: none;
    color: var(--color-text-subtle);
  }

  .tag-hero__body :global(p) {
    margin-block: 0 0.75rem;
  }

  .tag-hero__body :global(p:last-child) {
    margin-block-end: 0;
  }
</style>
