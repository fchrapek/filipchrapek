{/* Inlined to avoid FOUC. Parser-blocking so data-theme is set before CSS paints.
    Light by default. No system-preference detection — only the user's explicit choice persists. */}
<script is:inline>
	(() => {
		const KEY = "theme";
		const read = () => {
			try {
				return localStorage.getItem(KEY);
			} catch (_) {
				return null;
			}
		};
		const apply = (root) => {
			const target = root || document.documentElement;
			const next = read() === "dark" ? "dark" : "light";
			if (target.getAttribute("data-theme") !== next) {
				target.setAttribute("data-theme", next);
			}
		};

		apply();

		// View Transitions: carry the theme onto the incoming document BEFORE swap
		// so the snapshot used by the transition is painted with the right tokens.
		document.addEventListener("astro:before-swap", (event) => {
			apply(event.newDocument.documentElement);
		});

		// Safety net after swap (also covers history nav where before-swap may be bypassed).
		document.addEventListener("astro:after-swap", () => apply());

		// bfcache restore — re-apply so back/forward nav doesn't flash old theme.
		window.addEventListener("pageshow", (e) => {
			if (e.persisted) apply();
		});

		// Keep other tabs in sync.
		window.addEventListener("storage", (e) => {
			if (e.key === KEY) apply();
		});

		document.addEventListener("theme-change", (e) => {
			const next = e && e.detail && e.detail.theme === "dark" ? "dark" : "light";
			document.documentElement.setAttribute("data-theme", next);
			try {
				localStorage.setItem(KEY, next);
			} catch (_) {}
		});
	})();
</script>
