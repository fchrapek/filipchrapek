---
/**
 * Chip — small outlined pill with an optional leading icon.
 * Used for the copy-email affordance and (later) chat-style action pills.
 *
 * Slots:
 *   - icon  → inline SVG or character rendered before the label
 *   - (default) → label content
 */
interface Props {
  as?: "button" | "a" | "span";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  as = "span",
  href,
  type = "button",
  class: className,
  ...rest
} = Astro.props;

const Tag = as as "button" | "a" | "span";
const tagProps: Record<string, unknown> = { ...rest };
if (as === "button") tagProps.type = type;
if (as === "a" && href) tagProps.href = href;
---

<Tag class:list={["chip", className]} {...tagProps}>
  <span class="chip__icon" aria-hidden={Astro.slots.has("icon") ? "true" : undefined}>
    <slot name="icon" />
  </span>
  <span class="chip__label"><slot /></span>
</Tag>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    font-weight: var(--font-normal);
    line-height: 1;
    letter-spacing: var(--tracking-mono-wide);
    text-decoration: none;
    text-transform: inherit;
    cursor: default;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .chip:is(button, a) {
    cursor: pointer;
  }

  .chip:is(button, a):hover {
    border-color: var(--color-ink-40);
    background: var(--color-surface);
    color: var(--color-ink);
  }

  .chip:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .chip__icon {
    display: inline-flex;
    flex: none;
    justify-content: center;
    align-items: center;
  }

  .chip__icon:empty {
    display: none;
  }

  /* Size any slotted SVG consistently — pierces scope so the inline icon
     rendered by the caller picks up the right box. */
  .chip__icon :global(svg) {
    inline-size: 0.875em;
    block-size: 0.875em;
  }

  .chip__label {
    white-space: nowrap;
  }
</style>
