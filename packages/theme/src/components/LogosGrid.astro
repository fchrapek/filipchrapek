---
interface Logo {
  src: string;
  alt: string;
}

interface Props {
  class?: string;
  label: string;
  hint?: string;
  logos?: Logo[];
}

// Default set lives next to the 12 SVGs we ship in each site's public/logos/
// folder. Pages can pass their own list via the `logos` prop. Order is
// curated: row 1 leads with the picks, rows 2-3 balance heavier wordmarks
// against script/icon marks for visual rhythm.
const defaultLogos: Logo[] = [
  { src: "/logos/wygodnie.svg", alt: "wygodnie.pl" },
  { src: "/logos/hewalex.svg", alt: "Hewalex" },
  { src: "/logos/handmade.svg", alt: "handmade." },
  { src: "/logos/pum.svg", alt: "PUM" },
  { src: "/logos/huta19.svg", alt: "HUTA19" },
  { src: "/logos/fitlife.svg", alt: "FITlife" },
  { src: "/logos/total-active.svg", alt: "Total Active" },
  { src: "/logos/mammal-research-institute.svg", alt: "Mammal Research Institute" },
  { src: "/logos/lesny-klub-kolacyjny.svg", alt: "Leśny Klub Kolacyjny" },
  { src: "/logos/piotr-kurpiasz.svg", alt: "Piotr Kurpiasz" },
  { src: "/logos/fitness-platinum.svg", alt: "Fitness Platinum" },
  { src: "/logos/rebell.svg", alt: "Rebell" },
];

const { class: className, label, hint, logos = defaultLogos } = Astro.props;
---

<section class:list={["logos", className]} aria-labelledby="logos-label">
  <header class="logos__head">
    <h2 id="logos-label" class="logos__label">{label}</h2>
    {hint && <span class="logos__hint">{hint}</span>}
  </header>
  <ul class="logos__grid">
    {
      logos.map((logo) => (
        <li class="logos__item">
          <img
            class="logos__img"
            src={logo.src}
            alt={logo.alt}
            loading="lazy"
            decoding="async"
          />
        </li>
      ))
    }
  </ul>
</section>

<style>
  .logos__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-block-end: 0.875rem;
    border-block-end: 1px solid var(--color-hairline);
  }

  .logos__label {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-mono-ultra);
    text-transform: uppercase;
  }

  .logos__hint {
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  /* 12 logos divide cleanly into 6×2 on mobile and 3×4 on desktop. The cells
     are non-interactive so they keep just a hairline border — no background
     or hover state. */
  .logos__grid {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(2, 1fr);
    margin: var(--gap-section-head) 0 0;
    padding: 0;
    list-style: none;

    @media (min-width: 40rem) {
      gap: 0.75rem;
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .logos__item {
    display: flex;
    justify-content: center;
    align-items: center;
    aspect-ratio: 16 / 9;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
  }

  .logos__img {
    inline-size: auto;
    max-inline-size: 100%;
    block-size: auto;
    max-block-size: 3rem;
    opacity: 0.7;
    filter: grayscale(1);
  }

  /* Dark theme — most client logos are dark-on-white, so invert the rendered
     SVG so it reads as a light mark on the warm near-black surface. */
  :global(html[data-theme="dark"]) .logos__img {
    filter: grayscale(1) invert(1) brightness(1.05);
  }
</style>
