---
import { type CollectionEntry, render } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  note: CollectionEntry<"note"> | CollectionEntry<"notatka">;
  isPreview?: boolean | undefined;
};

const { as: Tag = "div", note, isPreview = false } = Astro.props;
const { Content } = await render(note);

const basePath = note.collection === "notatka" ? "/notatki/" : "/notes/";
---

<article
  class:list={[{ preview: isPreview }]}
  data-pagefind-body={isPreview ? false : true}
>
  <Tag class="section-title" class:list={{ "section-title--small": isPreview }}>
    {
      isPreview ? (
        <a href={`${basePath}${note.id}/`} class="title-link">
          {note.data.title}
        </a>
      ) : (
        <>{note.data.title}</>
      )
    }
  </Tag>
  <FormattedDate
    class="text--dimmed"
    size="sm"
    dateTimeOptions={{
      hour: "2-digit",
      minute: "2-digit",
      year: "2-digit",
      month: "2-digit",
      day: "2-digit",
    }}
    date={note.data.publishDate}
  />
  <div
    class:list={[
      "content",
      "prose",
      "prose--sm",
      { "content--preview": isPreview, "prose--dimmed": isPreview },
    ]}
  >
    <Content />
  </div>
</article>

<style>
  .preview {
    display: block;
    padding: 1rem 1.125rem;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .preview:hover {
    border-color: var(--color-ink-40);
    background-color: var(--color-surface-hover);
  }

  .title-link {
    display: block;
    margin-block-end: 0.25rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--text-h5);
    font-weight: var(--font-medium);
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
    text-decoration: none;
    text-transform: none;
    text-wrap: balance;
  }

  .preview :global(.text--dimmed) {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
  }

  .content {
    max-inline-size: none;
    margin-block-start: 0.75rem;
    color: var(--color-text-subtle);

    & > :global(p:last-of-type) {
      margin-block-end: 0;
    }
  }

  .content--preview {
    display: -webkit-box;
    overflow: hidden;
    color: var(--color-text-subtle);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    line-clamp: 6;
  }
</style>
