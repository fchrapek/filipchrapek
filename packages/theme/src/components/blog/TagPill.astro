---
interface Props {
  tag: string;
  href: string;
  count?: number;
  title?: string;
}

const { tag, href, count, title } = Astro.props;
---

<a class="tag-pill" {href} title={title}>
  <span class="tag-pill__name">#{tag}</span>
  {count !== undefined && <span class="tag-pill__count">{count}</span>}
</a>

<style>
  .tag-pill {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .tag-pill:hover {
    border-color: var(--color-ink-40);
    background: var(--color-surface-hover);
    color: var(--color-accent);
  }

  .tag-pill__name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tag-pill__count {
    flex: none;
    color: var(--color-text-dimmed);
  }
</style>
