---
import { type CollectionEntry, render } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  post: CollectionEntry<"post"> | CollectionEntry<"artykul">;
};

const { as: Tag = "div", post } = Astro.props;

const basePath = post.collection === "artykul" ? "/artykuly/" : "/posts/";
const slug = post.id.split("/").pop();
const postUrl = `${basePath}${slug}/`;

// Render the date as discrete parts so the · separators honor --gap-dot
const d = post.data.publishDate;
const dateParts = [
  String(d.getFullYear()),
  String(d.getMonth() + 1).padStart(2, "0"),
  String(d.getDate()).padStart(2, "0"),
];
const firstTag = post.data.tags?.[0];

// Pull reading time from the remark plugin frontmatter. `render()` is cached
// by astro:content so repeated calls across the listing are effectively free.
const { remarkPluginFrontmatter } = await render(post);
const readingTime: string | undefined = remarkPluginFrontmatter?.readingTime;
---

<a class="preview" href={postUrl}>
  <span class="preview__date">
    {
      dateParts.map((part, i) => (
        <>
          {i > 0 && <span class="preview__sep" aria-hidden="true" />}
          <span>{part}</span>
        </>
      ))
    }
  </span>
  <Tag class="preview__title">
    {post.data.draft && <span class="preview__draft">(Draft) </span>}
    {post.data.title}
  </Tag>
  {
    (firstTag || readingTime) && (
      <span class="preview__meta">
        {readingTime}
        {readingTime && firstTag && (
          <span class="preview__sep" aria-hidden="true" />
        )}
        {firstTag}
      </span>
    )
  }
</a>

<style>
  .preview {
    display: grid;
    gap: 0.25rem;
    grid-template-columns: 1fr auto;
    padding-block: 1rem;
    border-block-end: 1px solid var(--color-hairline);
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  @media (min-width: 40rem) {
    .preview {
      align-items: baseline;
      column-gap: 1.25rem;
      grid-template-columns: 6.875rem 1fr auto;
    }
  }

  .preview:hover .preview__title {
    color: var(--color-accent);
  }

  .preview__date {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-dot);
    order: 1;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono);
    white-space: nowrap;
  }

  .preview__title {
    grid-column: 1 / -1;
    order: 3;
    min-inline-size: 0; /* let the cell shrink so ellipsis kicks in */
    margin: 0;
    overflow: hidden;
    font-size: var(--text-h5);
    font-weight: var(--font-medium);
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  @media (min-width: 40rem) {
    .preview__title {
      grid-column: auto;
      order: 2;
    }
  }

  .preview__meta {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-dot);
    order: 2;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
    white-space: nowrap;
    justify-self: end;
  }

  @media (min-width: 40rem) {
    .preview__meta {
      order: 3;
    }
  }

  /* Real dot element — inherits currentColor so date and meta rows share it */
  .preview__sep {
    flex: none;
    inline-size: 2px;
    block-size: 2px;
    border-radius: 2px;
    background: currentColor;
  }

  .preview__draft {
    color: var(--color-red-500);
  }
</style>
