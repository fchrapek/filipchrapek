---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  post: CollectionEntry<"post"> | CollectionEntry<"artykul">;
  withArrow?: boolean;
};

const { as: Tag = "div", post, withArrow = false } = Astro.props;

const basePath = post.collection === "artykul" ? "/artykuly/" : "/posts/";
const slug = post.id.split("/").pop();
const postUrl = `${basePath}${slug}/`;

const d = post.data.publishDate;
const dateString = `${d.getFullYear()} · ${String(d.getMonth() + 1).padStart(2, "0")} · ${String(d.getDate()).padStart(2, "0")}`;
const firstTag = post.data.tags?.[0];
---

<a class="preview" href={postUrl}>
  <span class="preview__date">{dateString}</span>
  <div class="preview__main">
    <Tag class="preview__title">
      {post.data.draft && <span class="preview__draft">(Draft) </span>}
      {post.data.title}
    </Tag>
    {
      withArrow && (
        <svg
          class="preview__arrow"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M6 3.5L10.5 8L6 12.5"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      )
    }
  </div>
  {firstTag && <span class="preview__meta">{firstTag}</span>}
</a>

<style>
  .preview {
    display: grid;
    gap: 0.25rem;
    grid-template-columns: 1fr auto;
    padding-block: 1rem;
    border-block-end: 1px solid var(--color-hairline);
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  @media (min-width: 40rem) {
    .preview {
      align-items: baseline;
      gap: 1.25rem;
      grid-template-columns: 6.875rem 1fr auto;
    }
  }

  .preview:hover .preview__title {
    color: var(--color-accent);
  }

  .preview__date {
    order: 1;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: 0.71875rem;
    letter-spacing: var(--tracking-mono);
    white-space: nowrap;
  }

  .preview__main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    grid-column: 1 / -1;
    order: 3;
  }

  @media (min-width: 40rem) {
    .preview__main {
      grid-column: auto;
      order: 2;
    }
  }

  .preview__title {
    margin: 0;
    font-size: var(--text-h5);
    font-weight: var(--font-medium);
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
    transition: color 0.2s ease;
    text-wrap: balance;
  }

  .preview__arrow {
    flex: none;
    color: var(--color-text-dimmed);
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .preview:hover .preview__arrow {
    color: var(--color-accent);
    transform: translateX(0.25rem);
  }

  .preview__meta {
    order: 2;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
    white-space: nowrap;
    justify-self: end;
  }

  @media (min-width: 40rem) {
    .preview__meta {
      order: 3;
    }
  }

  .preview__draft {
    color: var(--color-red-500);
  }
</style>
