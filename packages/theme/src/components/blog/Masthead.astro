---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { siteConfig } from "@/site.config";
import { getLang, isPolish } from "@/utils/i18n";

interface Props {
  content: CollectionEntry<"post"> | CollectionEntry<"artykul">;
  readingTime: string;
}

const {
  content: { data },
  readingTime,
} = Astro.props;

const lang = getLang(siteConfig.lang);
const pl = isPolish(siteConfig.lang);
const labels = {
  draft: pl ? "(szkic)" : "(draft)",
  updated: pl ? "zaktualizowane" : "updated",
  viewMore: pl ? "Zobacz więcej artykułów z tagiem" : "View more posts tagged",
};

const date = data.publishDate;
const dateParts = [
  String(date.getFullYear()),
  String(date.getMonth() + 1).padStart(2, "0"),
  String(date.getDate()).padStart(2, "0"),
];
const firstTag = data.tags?.[0];
const remainingTags = data.tags?.slice(1) ?? [];
const tagHref = (t: string) => (pl ? `/tagi/${t}/` : `/tags/${t}/`);
---

{/* Meta line */}
<div class="masthead__meta">
  <span class="masthead__meta-date">
    {
      dateParts.map((part, i) => (
        <>
          {i > 0 && (
            <span class="masthead__meta-dot" aria-hidden="true" />
          )}
          <span>{part}</span>
        </>
      ))
    }
  </span>
  <span class="masthead__meta-dot" aria-hidden="true"></span>
  {firstTag && <a class="masthead__tag-primary" href={tagHref(firstTag)}>{firstTag}</a>}
  <span class="masthead__meta-dot" aria-hidden="true"></span>
  <span>{readingTime}</span>
  {data.draft && <span class="masthead__draft">{labels.draft}</span>}
</div>

{/* Title */}
<h1 class="masthead__title">{data.title}</h1>

{/* Subtitle */}
{data.description && <p class="masthead__lede">{data.description}</p>}

{/* Author / tags bar */}
<div class="masthead__byline">
  <div class="masthead__author">
    <span class="masthead__avatar" aria-hidden="true"></span>
    <div class="masthead__author-text">
      <span class="masthead__author-name">{siteConfig.author}</span>
      <span class="masthead__author-role">
        {siteConfig.location} · {siteConfig.tagline}
      </span>
    </div>
  </div>

  {
    remainingTags.length > 0 && (
      <div class="masthead__tags" aria-label={labels.viewMore}>
        {remainingTags.map((tag) => (
          <a class="masthead__tag" data-pagefind-filter={`tag:${tag}`} href={tagHref(tag)}>
            <span class="sr-only">{labels.viewMore}&nbsp;</span>#{tag}
          </a>
        ))}
      </div>
    )
  }
</div>

{
  data.coverImage && (
    <div class="masthead__cover">
      <Image
        alt={data.coverImage.alt}
        class="masthead__cover-img"
        layout="constrained"
        width={1040}
        height={585}
        priority
        src={data.coverImage.src}
      />
    </div>
  )
}

<style>
  .masthead__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--gap-dot);
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-ultra);
    text-transform: uppercase;
  }

  .masthead__meta-date {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-dot);
  }

  .masthead__meta-dot {
    display: inline-block;
    flex: none;
    inline-size: 2px;
    block-size: 2px;
    border-radius: 2px;
    background: currentColor;
  }

  .masthead__tag-primary {
    color: var(--color-accent);
    text-decoration: none;
  }

  .masthead__tag-primary:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .masthead__draft {
    color: var(--color-red-500);
  }

  .masthead__title {
    margin: 1rem 0 0.875rem;
    color: var(--color-ink);
    font-size: var(--text-h1);
    font-weight: var(--font-medium);
    line-height: var(--leading-h1);
    letter-spacing: var(--tracking-h1);
    text-wrap: balance;
  }

  .masthead__lede {
    margin: 0;
    color: var(--color-text-subtle);
    font-size: var(--text-lead);
    font-weight: var(--font-normal);
    line-height: var(--leading-lead);
    text-wrap: pretty;
  }

  .masthead__byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    margin-block: 1.75rem;
    padding-block-end: 1.5rem;
    border-block-end: 1px solid var(--color-hairline);
  }

  .masthead__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .masthead__avatar {
    flex: none;
    inline-size: 2.125rem; /* 34px */
    block-size: 2.125rem;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background-image: url("/filipchrapek-profile.jpg");
    background-repeat: no-repeat;
    background-position: center 25%;
    background-size: cover;
  }

  .masthead__author-text {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }

  .masthead__author-name {
    color: var(--color-ink);
    font-size: var(--text-small);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-tight);
  }

  .masthead__author-role {
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
  }

  .masthead__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-inline-start: auto;
  }

  .masthead__tag {
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .masthead__tag:hover {
    color: var(--color-accent);
  }

  .masthead__cover {
    aspect-ratio: 16 / 9;
    margin-block: 0 2rem;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
  }

  :global(.masthead__cover-img) {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }
</style>
