---
import CopyEmail from "@/components/CopyEmail.astro";
import { siteConfig } from "@/site.config";
import { getLang } from "@/utils/i18n";

const year = new Date().getFullYear();
const lang = getLang(siteConfig.lang);
const email = "hello@filipchrapek.com";
const emailLabel = lang === "pl" ? "e-mail" : "email";
const rssLabel = "rss";
const copy = `© ${year} · ${siteConfig.author}`;
---

<footer class="site-footer">
  <span class="site-footer__copy">{copy}</span>
  <div class="site-footer__links">
    <a href="/rss.xml">{rssLabel}</a>
    <CopyEmail email={email} label={emailLabel} />
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    margin-block-start: auto;
    padding-block: 1.5rem;
    border-block-start: 1px solid var(--color-hairline);
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-mono);
  }

  .site-footer__copy {
    white-space: nowrap;
  }

  .site-footer__links {
    display: flex;
    gap: 1.25rem;
  }

  .site-footer__links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer__links a:hover {
    color: var(--color-ink);
  }
</style>
