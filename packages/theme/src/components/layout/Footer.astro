---
import { siteConfig } from "@/site.config";
import { getLang } from "@/utils/i18n";

const year = new Date().getFullYear();
const lang = getLang(siteConfig.lang);
const emailLabel = "email";
const rssLabel = "rss";
const githubLabel = "github";
const copy = `© ${year} · ${siteConfig.author}`;
const contactHref = `mailto:${lang === "pl" ? "hello@filipchrapek.com" : "hello@filipchrapek.com"}`;
---

<footer class="site-footer">
  <span class="site-footer__copy">{copy}</span>
  <div class="site-footer__links">
    <a href="https://github.com/filipchrapek" rel="me">{githubLabel}</a>
    <a href="/rss.xml">{rssLabel}</a>
    <a href={contactHref}>{emailLabel}</a>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    margin-block-start: auto;
    padding-block: 1.5rem;
    border-block-start: 1px solid var(--color-hairline);
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: 0.75rem; /* 12px */
    letter-spacing: var(--tracking-mono);
  }

  .site-footer__copy {
    white-space: nowrap;
  }

  .site-footer__links {
    display: flex;
    gap: 1.25rem;
  }

  .site-footer__links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer__links a:hover {
    color: var(--color-ink);
  }
</style>
