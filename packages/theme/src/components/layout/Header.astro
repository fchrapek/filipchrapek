---
import { menuLinks } from "@/site.config";
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import MobileNav from "./MobileNav.astro";

export interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  class?: string;
  breadcrumbs?: Crumb[];
}

const { class: className, breadcrumbs = [] } = Astro.props;
const currentPath = Astro.url.pathname;
const filteredLinks = menuLinks.filter(
  (link) => !(link.path === "/" && currentPath === "/"),
);
---

<header class:list={["site-header", className]} id="main-header">
  <div class="site-header__wordmark">
    <a class="site-header__wordmark-home" href="/">
      <span>filip</span>
      <span class="site-header__wordmark-slash">/</span>
      <span>chrapek</span>
    </a>
    {
      breadcrumbs.map((crumb, i) => {
        const isLast = i === breadcrumbs.length - 1;
        return (
          <>
            <span
              class="site-header__wordmark-slash"
              aria-hidden="true"
            >
              /
            </span>
            {crumb.href && !isLast ? (
              <a class="site-header__wordmark-crumb" href={crumb.href}>
                {crumb.label}
              </a>
            ) : (
              <span
                class:list={[
                  "site-header__wordmark-crumb",
                  isLast && "site-header__wordmark-crumb--current",
                ]}
                aria-current={isLast ? "page" : undefined}
              >
                {crumb.label}
              </span>
            )}
          </>
        );
      })
    }
  </div>

  <div class="site-header__right">
    <nav class="site-header__nav" aria-label="Primary">
      {
        filteredLinks.map((link) => {
          const isActive =
            link.path === currentPath ||
            (link.path !== "/" && currentPath.startsWith(link.path));
          return (
            <a
              class:list={["site-header__nav-link", isActive && "is-active"]}
              href={link.path}
              aria-current={isActive ? "page" : false}
            >
              {link.title}
            </a>
          );
        })
      }
    </nav>

    <div class="site-header__tools">
      <Search />
      <ThemeToggle />
    </div>

    <MobileNav class="site-header__mobile" links={filteredLinks} />
  </div>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-block-end: 1.25rem;
    border-block-end: 1px solid var(--color-hairline);
  }

  .site-header__right {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .site-header__wordmark {
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: baseline;
    gap: var(--gap-dot);
    min-inline-size: 0;
    overflow: hidden;
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-mono);
  }

  .site-header__wordmark-home {
    display: inline-flex;
    flex: none;
    align-items: baseline;
    gap: var(--gap-dot);
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .site-header__wordmark-home:hover {
    opacity: 0.7;
  }

  .site-header__wordmark-slash {
    flex: none;
    color: var(--color-text-dimmed);
    font-weight: var(--font-normal);
  }

  .site-header__wordmark-crumb {
    flex: 0 1 auto;
    min-inline-size: 0;
    max-inline-size: 14rem;
    overflow: hidden;
    color: var(--color-ink);
    font-weight: var(--font-medium);
    text-decoration: none;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  a.site-header__wordmark-crumb:hover {
    color: var(--color-accent);
  }

  .site-header__wordmark-crumb--current {
    color: var(--color-accent);
  }

  .site-header__nav {
    display: none;
    flex: none;
    gap: 1.5rem;
    color: var(--color-text-dimmed);
    font-size: var(--text-small);

    @media (min-width: 40rem) {
      display: flex;
    }
  }

  .site-header__nav-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-header__nav-link:hover,
  .site-header__nav-link.is-active {
    color: var(--color-ink);
  }

  .site-header__tools {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.125rem;
  }

  .site-header__mobile {
    display: flex;
    flex: none;

    @media (min-width: 40rem) {
      display: none;
    }
  }
</style>
