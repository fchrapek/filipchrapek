---
import { siteConfig } from "@/site.config";
import { getLang } from "@/utils/i18n";

interface MenuLink {
  path: string;
  title: string;
}

interface Props {
  class?: string;
  currentPath?: string;
  links?: MenuLink[];
}

const {
  class: className,
  currentPath = Astro.url.pathname,
  links,
} = Astro.props;

const lang = getLang(siteConfig.lang);
const openLabel = lang === "pl" ? "Otwórz menu" : "Open menu";
const closeLabel = lang === "pl" ? "Zamknij menu" : "Close menu";

// Default menu if none provided
const defaultLinks = [
  {
    path: "/",
    title: lang === "pl" ? "Start" : "Home",
  },
];
const menuItems = (links ?? defaultLinks).filter(
  (link) => !(link.path === "/" && currentPath === "/"),
);
---

<mobile-nav class:list={["mobile-nav", className]} data-open="false">
  <button
    class="mobile-nav__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="mobile-nav-menu"
    data-mobile-nav-toggle
  >
    <span class="sr-only mobile-nav__toggle-label" data-open-label
      >{openLabel}</span
    >
    <span class="sr-only mobile-nav__toggle-label" data-close-label
      >{closeLabel}</span
    >
    <span class="mobile-nav__icon" aria-hidden="true">
      <span class="mobile-nav__line mobile-nav__line--top"></span>
      <span class="mobile-nav__line mobile-nav__line--bottom"></span>
    </span>
  </button>

  <div class="mobile-nav__sheet" id="mobile-nav-menu" role="dialog" aria-modal="true">
    <nav class="mobile-nav__menu" aria-label="Main">
      {
        menuItems.map((link) => (
          <a
            class:list={[
              "mobile-nav__link",
              currentPath === link.path && "is-active",
            ]}
            href={link.path}
            aria-current={currentPath === link.path ? "page" : false}
          >
            {link.title}
          </a>
        ))
      }
    </nav>
  </div>
</mobile-nav>

<script>
  class MobileNav extends HTMLElement {
    connectedCallback() {
      const toggle = this.querySelector<HTMLButtonElement>(
        "[data-mobile-nav-toggle]",
      );
      if (!toggle) return;

      const setOpen = (open: boolean) => {
        this.dataset.open = String(open);
        toggle.setAttribute("aria-expanded", String(open));
        document.documentElement.style.overflow = open ? "hidden" : "";
      };

      toggle.addEventListener("click", () => {
        setOpen(this.dataset.open !== "true");
      });

      this.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest(".mobile-nav__link")) {
          setOpen(false);
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && this.dataset.open === "true") {
          setOpen(false);
          toggle.focus();
        }
      });
    }
  }

  customElements.define("mobile-nav", MobileNav);
</script>

<style>
  .mobile-nav {
    position: relative;
    align-items: center;
  }

  .mobile-nav__toggle {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    inline-size: 2.5rem;
    block-size: 2.5rem;
    padding: 0;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .mobile-nav__toggle:hover {
    background-color: var(--color-ink-04);
  }

  .mobile-nav__toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .mobile-nav__toggle-label[data-open-label] {
    display: inline;
  }

  .mobile-nav__toggle-label[data-close-label] {
    display: none;
  }

  .mobile-nav[data-open="true"] .mobile-nav__toggle-label[data-open-label] {
    display: none;
  }

  .mobile-nav[data-open="true"] .mobile-nav__toggle-label[data-close-label] {
    display: inline;
  }

  .mobile-nav__icon {
    position: relative;
    display: block;
    inline-size: 1.125rem;
    block-size: 0.625rem;
  }

  .mobile-nav__line {
    position: absolute;
    inset-inline: 0;
    block-size: 1.25px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 0.35s cubic-bezier(0.33, 1, 0.68, 1),
      inset-block-start 0.25s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .mobile-nav__line--top {
    inset-block-start: 0;
  }

  .mobile-nav__line--bottom {
    inset-block-end: 0;
  }

  .mobile-nav[data-open="true"] .mobile-nav__line--top {
    inset-block-start: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  .mobile-nav[data-open="true"] .mobile-nav__line--bottom {
    inset-block-end: 50%;
    transform: translateY(50%) rotate(-45deg);
  }

  .mobile-nav__sheet {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    padding: 5rem 2rem 3rem;
    background-color: color-mix(
      in srgb,
      var(--color-bg) 92%,
      transparent
    );
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.32s cubic-bezier(0.33, 1, 0.68, 1),
      visibility 0.32s step-end;
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
    place-items: center;
  }

  .mobile-nav[data-open="true"] .mobile-nav__sheet {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 0.32s cubic-bezier(0.33, 1, 0.68, 1),
      visibility 0s;
  }

  .mobile-nav__menu {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    transform: translateY(0.75rem);
    transition:
      opacity 0.32s cubic-bezier(0.33, 1, 0.68, 1) 0.05s,
      transform 0.32s cubic-bezier(0.33, 1, 0.68, 1) 0.05s;
  }

  .mobile-nav[data-open="true"] .mobile-nav__menu {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav__link {
    position: relative;
    padding: 0.5rem 1rem;
    color: var(--color-ink-55);
    font-size: 1.5rem; /* 24px */
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-tight);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-nav__link:hover,
  .mobile-nav__link.is-active {
    color: var(--color-ink);
  }

  .mobile-nav__link.is-active::before {
    content: "";
    position: absolute;
    inset-block-end: 0.125rem;
    inset-inline-start: 1rem;
    inline-size: calc(100% - 2rem);
    block-size: 1px;
    background: var(--color-accent);
  }

  @media (min-width: 40rem) {
    .mobile-nav {
      display: none;
    }
  }
</style>
