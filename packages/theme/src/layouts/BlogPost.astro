---
import { type CollectionEntry, render } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import StructuredData from "@/components/StructuredData.astro";
import { siteConfig } from "@/site.config";
import { getLang, isPolish } from "@/utils/i18n";
import { getAllPosts } from "@/data/post";

import BaseLayout from "./Base.astro";

type PostEntry = CollectionEntry<"post"> | CollectionEntry<"artykul">;

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const slug = post.id.split("/").pop()!;
const socialImage = ogImage ?? `/og-image/${slug}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { remarkPluginFrontmatter, headings } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;

const lang = getLang(siteConfig.lang);
const pl = isPolish(siteConfig.lang);
const labels = {
  backToTop: pl ? "Wróć na górę" : "Back to top",
  allPosts: pl ? "← wszystkie artykuły" : "← all posts",
  onThisPage: pl ? "Na tej stronie" : "On this page",
  updated: pl ? "zaktualizowane" : "updated",
  end: pl ? "koniec" : "end",
  morePosts: pl ? "Więcej artykułów" : "More posts",
  allPostsFooter: pl ? "wszystkie artykuły →" : "all posts →",
  previous: pl ? "Poprzedni" : "Previous",
  next: pl ? "Następny" : "Next",
  sectionLabel: pl ? "artykuły" : "posts",
};

const sectionPath = pl ? "/artykuly/" : "/posts/";

// TOC — keep h2 only (matches the design's numbered list cadence)
const tocItems = headings
  .filter((h) => h.depth === 2)
  .map((h, i) => ({
    ...h,
    num: String(i + 1).padStart(2, "0"),
  }));

// More posts — fetch siblings, exclude current, sort by date desc, take 3
const allPosts = await getAllPosts();
const morePosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  )
  .slice(0, 3);

// Prev / next
const sorted = [...allPosts].sort(
  (a, b) => a.data.publishDate.getTime() - b.data.publishDate.getTime(),
);
const idx = sorted.findIndex((p) => p.id === post.id);
const prevPost = idx > 0 ? sorted[idx - 1] : null;
const nextPost = idx >= 0 && idx < sorted.length - 1 ? sorted[idx + 1] : null;

const postHref = (p: PostEntry) =>
  `${sectionPath}${p.id.split("/").pop()}/`;

const dateFmt = (d: Date) => {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const dd = String(d.getDate()).padStart(2, "0");
  return `${y} · ${m} · ${dd}`;
};

const wordCount = remarkPluginFrontmatter.wordCount as number | undefined;
---

<BaseLayout
  meta={{
    articleDate,
    description,
    ogImage: socialImage,
    title,
  }}
  breadcrumbs={[
    { label: labels.sectionLabel, href: sectionPath },
    { label: title },
  ]}
  reading
>
  <StructuredData post={post} type="article" />
  <article class="blog-post" data-pagefind-body>
    <div class="blog-post__layout">
      {/* Article body — now rendered first so desktop TOC can live on the right */}
      <div class="blog-post__article" id="blog-hero">
        <Masthead content={post} readingTime={readingTime} />
        <div class="blog-post__content prose">
          <slot />
          <WebMentions />
        </div>

        <div class="blog-post__end" aria-hidden="true">
          <span class="blog-post__end-line"></span>
          <span class="blog-post__end-label">{labels.end}</span>
          <span class="blog-post__end-line"></span>
        </div>

        {
          morePosts.length > 0 && (
            <section class="blog-post__more" aria-label={labels.morePosts}>
              <header class="blog-post__more-head">
                <h2 class="blog-post__more-label">{labels.morePosts}</h2>
                <a class="blog-post__more-all" href={sectionPath}>
                  {labels.allPostsFooter}
                </a>
              </header>
              {morePosts.map((p) => (
                <PostPreview post={p} />
              ))}
            </section>
          )
        }

        {
          (prevPost || nextPost) && (
            <nav class="blog-post__nav" aria-label={labels.morePosts}>
              {prevPost ? (
                <a
                  class="blog-post__nav-link blog-post__nav-link--prev"
                  href={postHref(prevPost)}
                >
                  <span class="blog-post__nav-kicker">← {labels.previous}</span>
                  <span class="blog-post__nav-title">{prevPost.data.title}</span>
                </a>
              ) : (
                <span />
              )}
              {nextPost ? (
                <a
                  class="blog-post__nav-link blog-post__nav-link--next"
                  href={postHref(nextPost)}
                >
                  <span class="blog-post__nav-kicker">{labels.next} →</span>
                  <span class="blog-post__nav-title">{nextPost.data.title}</span>
                </a>
              ) : (
                <span />
              )}
            </nav>
          )
        }
      </div>

      {/* TOC — mobile: collapsible widget above article (via CSS order);
                   desktop (≥84rem): sticky in the right-side gutter. */}
      <aside class="blog-post__toc" aria-label={labels.onThisPage} data-toc-open="false">
        <button
          class="blog-post__toc-trigger"
          type="button"
          aria-expanded="false"
          aria-controls="post-toc-panel"
          data-toc-trigger
        >
          <span class="blog-post__toc-trigger-label">
            {labels.onThisPage}
          </span>
          {
            tocItems.length > 0 && (
              <span class="blog-post__toc-trigger-count">
                {String(tocItems.length).padStart(2, "0")}
              </span>
            )
          }
          <svg
            class="blog-post__toc-chevron"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 6l4 4 4-4" />
          </svg>
        </button>

        <div class="blog-post__toc-panel" id="post-toc-panel">
          <div class="blog-post__toc-panel-inner">
            <a class="blog-post__toc-back" href={sectionPath}>
              {labels.allPosts}
            </a>
            <div class="blog-post__toc-divider" aria-hidden="true"></div>
            {
              tocItems.length > 0 && (
                <>
                  <div class="blog-post__toc-label">{labels.onThisPage}</div>
                  <ol class="blog-post__toc-list">
                    {tocItems.map((h) => (
                      <li>
                        <a
                          class="blog-post__toc-item"
                          href={`#${h.slug}`}
                          data-toc-link={h.slug}
                        >
                          <span class="blog-post__toc-num">{h.num}</span>
                          <span>{h.text}</span>
                        </a>
                      </li>
                    ))}
                  </ol>
                  <div class="blog-post__toc-divider" aria-hidden="true"></div>
                </>
              )
            }
            <div class="blog-post__toc-meta">
              <span>
                {readingTime}
                {wordCount ? ` · ${wordCount.toLocaleString()} ${pl ? "słów" : "words"}` : ""}
              </span>
              {
                updatedDate && (
                  <span>
                    {labels.updated} {dateFmt(updatedDate)}
                  </span>
                )
              }
            </div>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <button class="back-to-top" data-show="false" id="to-top-btn" type="button">
    <span class="sr-only">{labels.backToTop}</span>
    <svg
      aria-hidden="true"
      class="back-to-top-icon"
      fill="none"
      focusable="false"
      stroke="currentColor"
      stroke-width="1.5"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M4.5 15.75l7.5-7.5 7.5 7.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
</BaseLayout>

<script>
  const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
  const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

  if (scrollBtn && targetHeader) {
    scrollBtn.addEventListener("click", () => {
      document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        scrollBtn.dataset.show = (!entry.isIntersecting).toString();
      });
    });
    observer.observe(targetHeader);
  }

  // TOC highlighting based on scroll position
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(
    "[data-toc-link]",
  );

  if (tocLinks.length > 0) {
    const targets = Array.from(tocLinks)
      .map((l) => {
        const id = l.dataset.tocLink;
        return id ? document.getElementById(id) : null;
      })
      .filter((el): el is HTMLElement => el !== null);

    const setActive = (id: string | null) => {
      tocLinks.forEach((l) => {
        if (l.dataset.tocLink === id) {
          l.setAttribute("aria-current", "true");
          l.classList.add("is-active");
        } else {
          l.removeAttribute("aria-current");
          l.classList.remove("is-active");
        }
      });
    };

    const headingObserver = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      { rootMargin: "0% 0% -70% 0%", threshold: 0 },
    );

    targets.forEach((t) => headingObserver.observe(t));
  }

  // Mobile TOC toggle. Desktop collapses the trigger via CSS so this is a no-op there.
  const tocAside = document.querySelector<HTMLElement>(".blog-post__toc");
  const tocTrigger = document.querySelector<HTMLButtonElement>(
    "[data-toc-trigger]",
  );

  if (tocAside && tocTrigger) {
    const setOpen = (open: boolean) => {
      tocAside.dataset.tocOpen = String(open);
      tocTrigger.setAttribute("aria-expanded", String(open));
    };

    tocTrigger.addEventListener("click", () => {
      setOpen(tocAside.dataset.tocOpen !== "true");
    });

    // Collapse when a TOC item is tapped so the user sees the target heading.
    tocAside.addEventListener("click", (e) => {
      const link = (e.target as HTMLElement).closest("[data-toc-link]");
      if (link) setOpen(false);
    });
  }
</script>
