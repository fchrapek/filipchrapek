---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import CopyEmail from "@/components/CopyEmail.astro";
import LogosGrid from "@/components/LogosGrid.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import Search from "@/components/Search.astro";
import StructuredData from "@/components/StructuredData.astro";
import Testimonials from "@/components/Testimonials.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { siteConfig } from "@/site.config";
import { isPolish } from "@/utils/i18n";
import type { CollectionEntry } from "astro:content";

type PostEntry = CollectionEntry<"post"> | CollectionEntry<"artykul">;
type NoteEntry = CollectionEntry<"note"> | CollectionEntry<"notatka">;

interface Props {
  posts: PostEntry[];
  notes: NoteEntry[];
}

const { posts, notes } = Astro.props;
const pl = isPolish(siteConfig.lang);

const t = pl
  ? {
      status: "Dostępny · Q2 2026",
      heroLead: "Samouk generalista,",
      heroMid: "wiecznie ciekawy",
      heroTail: "freelancer.",
      heroBody:
        "Od lat skupiam się na web devie, designie wszelkich odmian i produktywności bez „guru” BS.",
      email: "hello@filipchrapek.com",
      location: `${siteConfig.location} → zdalnie`,
      chatHint: "Napisz wiadomość",
      chatSeed:
        "Cześć Filip — potrzebujemy prostej strony marketingowej dla małego SaaS. Termin ~3 tygodnie, najlepiej w Astro. Możemy pogadać w przyszłym tygodniu?",
      chatNote:
        "Podgląd — czat to jeszcze makieta, pracujemy nad nim. Pisz na maila.",
      sendLabel: "Wyślij",
      attach: "załącz",
      proposeTime: "zaproponuj termin",
      services: "Usługi",
      servicesHint: "trzy, zrobione porządnie",
      writing: "Artykuły",
      writingHint: "ostatnie",
      notesSection: "Notatki",
      notesHint: "krótkie formy",
      allPosts: "wszystkie artykuły →",
      allNotes: "wszystkie notatki →",
      kindWords: "Dobre słowa",
      kindWordsHint: "od klientów",
      workedWith: "Pracowali ze mną",
      workedWithHint: "wybrane",
      menu: "Menu",
      nav: [
        { label: "O mnie", href: "/o-mnie/" },
        { label: "Blog", href: "/artykuly/" },
      ],
      services1Title: "Web development",
      services1Body:
        "Małe, ostre strony i aplikacje webowe. Astro, React, cokolwiek pasuje. Bez 14-stopniowych pipeline’ów na bloga.",
      services2Title: "Design wszelkich odmian",
      services2Body:
        "Interfejsy, identyfikacja, czasem logo. Mniej moodboardów, więcej dowożenia. Figma opcjonalnie, smak obowiązkowy.",
      services3Title: "Systemy i produktywność",
      services3Body:
        "Ustawianie nudnych rur, żeby praca przestała przypominać pasterzenie kotów. Obsidian, DDEV, automatyzacja — bez guru bullshitu.",
      postsHref: "/artykuly/",
      notesHref: "/notatki/",
      monthsSuffix: "mies",
      yearsSuffix: "r",
    }
  : {
      status: "Available · Q2 2026",
      heroLead: "Self-taught generalist,",
      heroMid: "perpetually curious",
      heroTail: "freelancer.",
      heroBody:
        "For years now, my professional focus is web dev, design of all flavors, and productivity without the ‘guru’ BS.",
      email: "hello@filipchrapek.com",
      location: `${siteConfig.location} → remote`,
      chatHint: "Drop a message",
      chatSeed:
        "Hey Filip — we need a simple marketing site for a small SaaS. Timeline is ~3 weeks, ideally using Astro. Available to chat next week?",
      chatNote:
        "Preview — chat is still a mockup, we're working on it. Email me for now.",
      sendLabel: "Send",
      attach: "attach",
      proposeTime: "propose time",
      services: "Services",
      servicesHint: "three, done properly",
      writing: "Writing",
      writingHint: "recent",
      notesSection: "Notes",
      notesHint: "short-form",
      allPosts: "all posts →",
      allNotes: "all notes →",
      kindWords: "Kind words",
      kindWordsHint: "from clients",
      workedWith: "Worked with",
      workedWithHint: "selected",
      menu: "Menu",
      nav: [
        { label: "About", href: "/about/" },
        { label: "Blog", href: "/posts/" },
      ],
      services1Title: "Web development",
      services1Body:
        "Small, sharp sites and web apps. Astro, React, whatever actually fits. No 14-step build pipelines for a blog.",
      services2Title: "Design of all flavors",
      services2Body:
        "Interfaces, identity, the occasional logo. Less moodboard, more shipping. Figma optional, taste mandatory.",
      services3Title: "Systems & productivity",
      services3Body:
        "Setting up the boring pipes so work stops feeling like herding cats. Obsidian, DDEV, automation — minus the guru bullshit.",
      postsHref: "/posts/",
      notesHref: "/notes/",
      monthsSuffix: "mo",
      yearsSuffix: "y",
    };

const services = [
  { num: "01", title: t.services1Title, body: t.services1Body, icon: "code" },
  { num: "02", title: t.services2Title, body: t.services2Body, icon: "design" },
  {
    num: "03",
    title: t.services3Title,
    body: t.services3Body,
    icon: "systems",
  },
];

const recentPosts = [...posts]
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const recentNotes = [...notes]
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 6);

function formatDate(d: Date): string {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y} · ${m} · ${day}`;
}

function relTime(d: Date): string {
  const diffMs = Date.now() - d.getTime();
  const days = Math.max(1, Math.floor(diffMs / 86_400_000));
  if (days < 30) return `${days}d`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}${t.monthsSuffix}`;
  const years = Math.floor(months / 12);
  return `${years}${t.yearsSuffix}`;
}

function postHref(slug: string) {
  return `${t.postsHref}${slug}/`;
}

function noteHref(slug: string) {
  return `${t.notesHref}${slug}/`;
}

function postSlug(p: PostEntry): string {
  return p.id.split("/").pop() ?? p.id;
}

function noteSlug(n: NoteEntry): string {
  return n.id.split("/").pop() ?? n.id;
}
---

<html lang={siteConfig.lang}>
  <head>
    <ThemeProvider />
    <ClientRouter />
    <BaseHead title="Home" description={siteConfig.description} />
    <StructuredData type="website" />
  </head>
  <body>
    <div class="home">
      <div class="home__inner">
        {/* Header */}
        <header class="home__header">
          <a class="home__wordmark" href="/">
            <span class="home__wordmark-name">filip</span>
            <span class="home__wordmark-slash">/</span>
            <span class="home__wordmark-name">chrapek</span>
          </a>
          <div class="home__header-right">
            <nav class="home__nav" aria-label="Primary">
              {
                t.nav.map((n) => (
                  <a href={n.href} class="home__nav-link">
                    {n.label}
                  </a>
                ))
              }
            </nav>
            <div class="home__tools">
              <Search />
              <ThemeToggle />
            </div>
            <button
              class="home__menu-button"
              type="button"
              aria-label={t.menu}
              data-home-menu-toggle
            >
              <span class="home__menu-line"></span>
              <span class="home__menu-line"></span>
            </button>
          </div>
        </header>

        {/* Hero */}
        <section class="home__hero home__section">
          <div class="home__hero-main">
            <div class="home__hero-heading">
              <span class="home__avatar" aria-hidden="true"></span>
              <div>
                <div class="home__hero-name">{siteConfig.author}</div>
                <div class="home__hero-status">
                  <span class="home__status-dot" aria-hidden="true"></span>
                  {t.status}
                </div>
              </div>
            </div>

            <h1 class="home__hero-title">
              {t.heroLead}{" "}
              <span class="home__hero-muted">{t.heroMid}</span>{" "}
              {t.heroTail}
            </h1>

            <p class="home__hero-body">{t.heroBody}</p>

            <div class="home__hero-meta">
              <span>{t.location}</span>
              <CopyEmail email={t.email} />
            </div>
          </div>

          {/* Chat placeholder (visual only) */}
          <aside class="home__chat" aria-label={t.chatHint}>
            <div class="home__chat-header">
              <div class="home__chat-hint">
                <span class="home__status-dot" aria-hidden="true"></span>
                {t.chatHint}
              </div>
              <span class="home__chat-kbd">⌘ + ↵</span>
            </div>
            <div class="home__chat-body">
              <span class="home__chat-avatar" aria-hidden="true"></span>
              <div class="home__chat-stack">
                <p class="home__chat-message">{t.chatSeed}</p>
                <p class="home__chat-note">{t.chatNote}</p>
              </div>
            </div>
            <div class="home__chat-footer">
              <div class="home__chat-tools">
                <span class="home__chat-chip">📎 {t.attach}</span>
                <span class="home__chat-chip">🗓 {t.proposeTime}</span>
              </div>
              <a class="home__chat-send" href={`mailto:${t.email}`}>
                {t.sendLabel}
                <span class="home__chat-send-kbd">↵</span>
              </a>
            </div>
          </aside>
        </section>

        {/* Services */}
        <section class="home__section" aria-labelledby="home-services">
          <header class="home__section-head">
            <h2 id="home-services" class="home__section-label">{t.services}</h2>
            <span class="home__section-hint">{t.servicesHint}</span>
          </header>
          <ol class="home__grid home__grid--three home__list">
            {
              services.map((s) => (
                <li>
                  <article class="home__card home__card--service">
                    <div class="home__card-top">
                      <svg
                        class="home__service-icon"
                        viewBox="0 0 32 32"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.25"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        {s.icon === "code" && (
                          <>
                            <path d="M11 10 L5 16 L11 22" />
                            <path d="M21 10 L27 16 L21 22" />
                            <path d="M18 8 L14 24" />
                          </>
                        )}
                        {s.icon === "design" && (
                          <>
                            <rect x="5" y="5" width="15" height="15" rx="1" />
                            <circle cx="20" cy="20" r="7" />
                          </>
                        )}
                        {s.icon === "systems" && (
                          <>
                            <circle cx="16" cy="16" r="11" />
                            <circle cx="16" cy="16" r="5" />
                            <path d="M16 2 L16 5" />
                            <path d="M16 27 L16 30" />
                            <path d="M2 16 L5 16" />
                            <path d="M27 16 L30 16" />
                          </>
                        )}
                      </svg>
                      <span class="home__card-num">{s.num}</span>
                    </div>
                    <h3 class="home__card-title">{s.title}</h3>
                    <p class="home__card-body">{s.body}</p>
                  </article>
                </li>
              ))
            }
          </ol>
        </section>

        {/* Logos — clients / brands shipped with */}
        <LogosGrid
          class="home__section"
          label={t.workedWith}
          hint={t.workedWithHint}
        />

        {/* Testimonials — sourced from the `testimonial` content collection */}
        <Testimonials
          class="home__section"
          label={t.kindWords}
          hint={t.kindWordsHint}
        />

        {/* Writing */}
        <section class="home__section" aria-labelledby="home-writing">
          <header class="home__section-head">
            <h2 id="home-writing" class="home__section-label">{t.writing}</h2>
            <span class="home__section-hint">{t.writingHint}</span>
          </header>
          <ol class="home__list home__list--stacked">
            {
              recentPosts.map((p) => (
                <li>
                  <PostPreview post={p} as="h3" />
                </li>
              ))
            }
          </ol>
          <div class="home__all-link">
            <a href={t.postsHref}>{t.allPosts}</a>
          </div>
        </section>

        {/* Notes */}
        <section class="home__section" aria-labelledby="home-notes">
          <header class="home__section-head">
            <h2 id="home-notes" class="home__section-label">
              {t.notesSection}
            </h2>
            <span class="home__section-hint">{t.notesHint}</span>
          </header>
          <ol class="home__grid home__grid--notes home__list">
            {
              recentNotes.map((n) => (
                <li>
                  <a
                    href={noteHref(noteSlug(n))}
                    class="home__card home__card--note"
                  >
                    <div class="home__card-top">
                      <span>{formatDate(n.data.publishDate)}</span>
                      <span>{relTime(n.data.publishDate)}</span>
                    </div>
                    <h3 class="home__note-title">{n.data.title}</h3>
                    {n.data.description && (
                      <p class="home__card-body">{n.data.description}</p>
                    )}
                  </a>
                </li>
              ))
            }
          </ol>
          <div class="home__all-link">
            <a href={t.notesHref}>{t.allNotes}</a>
          </div>
        </section>

        {/* Footer */}
        <footer class="home__footer">
          <span class="home__footer-copy">© 2026 · {siteConfig.author}</span>
          <div class="home__footer-links">
            <a href="/rss.xml">rss</a>
            <CopyEmail email={t.email} label={pl ? "e-mail" : "email"} />
          </div>
        </footer>
      </div>
    </div>

    <script>
      // Simple toggle for mobile — reveal .home__nav as overlay on click
      const homeEl = document.querySelector<HTMLElement>(".home");
      const btn = document.querySelector<HTMLButtonElement>(
        "[data-home-menu-toggle]",
      );
      if (homeEl && btn) {
        btn.addEventListener("click", () => {
          const open = homeEl.dataset.menuOpen === "true";
          homeEl.dataset.menuOpen = String(!open);
          btn.setAttribute("aria-expanded", String(!open));
          document.documentElement.style.overflow = !open ? "hidden" : "";
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && homeEl.dataset.menuOpen === "true") {
            homeEl.dataset.menuOpen = "false";
            btn.setAttribute("aria-expanded", "false");
            document.documentElement.style.overflow = "";
            btn.focus();
          }
        });

        homeEl.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          if (target.closest(".home__nav-link")) {
            homeEl.dataset.menuOpen = "false";
            btn.setAttribute("aria-expanded", "false");
            document.documentElement.style.overflow = "";
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .home {
    min-block-size: 100vh;
    background-color: var(--color-bg);
    color: var(--color-ink);
  }

  .home__inner {
    max-inline-size: var(--content-max);
    margin-inline: auto;
    padding: 1.25rem 1.25rem 2.5rem;

    @media (min-width: 40rem) {
      padding: var(--content-pad-block) var(--content-pad-inline);
    }
  }

  /* Header */
  .home__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block-end: 1.25rem;
    border-block-end: 1px solid var(--color-hairline);
  }

  .home__header-right {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .home__tools {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
  }

  .home__wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-dot);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-mono);
    text-decoration: none;
  }

  .home__wordmark-slash {
    color: var(--color-text-dimmed);
    font-weight: var(--font-normal);
  }

  .home__nav {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    padding: 5rem 2rem 3rem;
    background-color: color-mix(in srgb, var(--color-bg) 92%, transparent);
    color: var(--color-ink-55);
    font-family: var(--font-mono);
    font-size: var(--text-h3);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-mono);
    text-transform: lowercase;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.32s cubic-bezier(0.33, 1, 0.68, 1),
      visibility 0.32s step-end;
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);

    @media (min-width: 40rem) {
      position: static;
      z-index: auto;
      flex-direction: row;
      justify-content: normal;
      align-items: normal;
      gap: 1.5rem;
      padding: 0;
      background-color: transparent;
      color: var(--color-text-dimmed);
      font-family: inherit;
      font-size: var(--text-small);
      font-weight: inherit;
      letter-spacing: normal;
      text-transform: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: none;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
    }
  }

  /* Mobile overlay open state — triggered by the hamburger toggle. Desktop
     never flips the attribute because the menu button is display: none there. */
  .home[data-menu-open="true"] .home__nav {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 0.32s cubic-bezier(0.33, 1, 0.68, 1),
      visibility 0s;
  }

  .home__nav-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .home__nav-link:hover {
    color: var(--color-ink);
  }

  .home__menu-button {
    position: relative;
    z-index: 90; /* keep above the overlay so the close X stays tappable */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    inline-size: 2.5rem;
    block-size: 2.5rem;
    padding: 0;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
    transition: background-color 0.2s ease;

    @media (min-width: 40rem) {
      display: none;
    }
  }

  .home__menu-button:hover {
    background-color: var(--color-ink-04);
  }

  .home__menu-button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .home__menu-line {
    display: block;
    inline-size: 1.125rem;
    block-size: 1.25px;
    background: currentColor;
    transform-origin: center;
    transition: transform 0.35s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .home[data-menu-open="true"] .home__menu-line:first-child {
    transform: translateY(2.625px) rotate(45deg);
  }

  .home[data-menu-open="true"] .home__menu-line:last-child {
    transform: translateY(-2.625px) rotate(-45deg);
  }

  /* Hero */
  .home__hero {
    display: grid;
    align-items: start;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    /* bottom spacing is owned by --space-section on the next sibling */
    padding-block: 2rem 0;

    @media (min-width: 40rem) {
      /* Bottom gap to the next section comes from --space-section (via
         .home__section on this element). Keep top padding for breathing. */
      gap: 2rem;
      grid-template-columns: 1.2fr 1fr;
      padding-block: 1.75rem 0;
    }
  }

  .home__hero-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-block-end: 1.375rem;
  }

  .home__avatar,
  .home__chat-avatar {
    flex: none;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background-image: url("/filipchrapek-profile.jpg");
    background-repeat: no-repeat;
    background-position: center 25%;
    background-size: cover;
  }

  .home__avatar {
    inline-size: 2.25rem;
    block-size: 2.25rem;

    @media (min-width: 40rem) {
      inline-size: 2.5rem;
      block-size: 2.5rem;
    }
  }

  .home__hero-name {
    color: var(--color-ink);
    font-size: var(--text-small);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-tight);
  }

  .home__hero-status {
    display: flex;
    align-items: center;
    gap: var(--gap-dot);
    margin-block-start: 0.125rem;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .home__status-dot {
    flex: none;
    inline-size: 0.375rem;
    block-size: 0.375rem;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
  }

  .home__hero-title {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-h1);
    font-weight: var(--font-medium);
    line-height: var(--leading-h1);
    letter-spacing: var(--tracking-h1);
    text-wrap: balance;
  }

  .home__hero-muted {
    color: var(--color-text-dimmed);
  }

  .home__hero-body {
    margin: 1rem 0 0;
    color: var(--color-text-subtle);
    font-size: var(--text-body);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .home__hero-meta {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 0.375rem;
    margin-block-start: 1.375rem;
    color: var(--color-text-dimmed);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;

    @media (min-width: 40rem) {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
  }

  .home__hero-meta a {
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .home__hero-meta a:hover {
    color: var(--color-accent);
  }

  /* Chat placeholder */
  .home__chat {
    padding: 0.875rem;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .home__chat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-block-end: 0.625rem;
